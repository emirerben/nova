# Secrets — never commit
.env
.env.*
!.env.example
!.env.local-render.example

# Video files — never commit (large, contain user content)
*.mp4 *.mov *.mkv *.avi *.webm *.hevc *.m4v *.3gp *.heic
*.d.ts.map
raw_uploads/
processed_outputs/
tmp/

# Dev environment runtime state (dev-auto.sh logs + PIDs)
.dev/

# Local-render outputs (downloaded MP4s from `make local-render`)
.local-render/

# Pre-PR overlay-verify outputs (reports + montages from `make verify-overlays`)
.overlay-verify/

# Python
__pycache__/
.venv/
.ruff_cache/
*.pyc *.pyo
dist/
*.egg-info/

# Node / Next.js
node_modules/
.next/
.turbo/
out/
*.tsbuildinfo

# OS
.DS_Store
.gstack/

# Firebase
firebase-debug.log
.devtest/

# Weekly TikTok research raw dumps (intermediate, reproducible — not committed).
research/tiktok/raw/

# gbrain per-worktree pin (machine-local, not shared)
.gbrain-source
