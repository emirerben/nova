# Secrets — never commit
.env
.env.*
!.env.example

# Video files — never commit (large, contain user content)
*.mp4 *.mov *.mkv *.avi *.webm *.hevc *.m4v *.3gp *.heic
*.d.ts.map
raw_uploads/
processed_outputs/
tmp/

# Dev environment runtime state (dev-auto.sh logs + PIDs)
.dev/

# Python
__pycache__/
.venv/
.ruff_cache/
*.pyc *.pyo
dist/
*.egg-info/

# Node / Next.js
node_modules/
.next/
.turbo/
out/
*.tsbuildinfo

# OS
.DS_Store
.gstack/

# Firebase
firebase-debug.log
