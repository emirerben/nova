# Local-render parity env — copy to .env.local-render and fill in secrets.
#
#     cp .env.local-render.example .env.local-render
#
# Loaded by docker-compose.local-render.yml. The point of this file is to make
# explicit every setting that can cause local-vs-prod render drift. Defaults
# below match Fly.io secrets (.env.example documents the others).
#
# If a value below differs from what Fly has set, your local render will not
# match prod. `make local-render` prints these values at runtime so you can
# spot-check.

# ── Storage ───────────────────────────────────────────────────────────────────
# Match Fly: the dev bucket is fine; render output uses a per-job prefix that
# the bucket-lifecycle rule cleans up after 24h.
STORAGE_BUCKET=nova-videos-dev
STORAGE_PROVIDER=gcs
GCLOUD_PROJECT=

# GCS credentials — paste the same service-account JSON Fly uses
# (`fly secrets list --app nova-video` → GOOGLE_SERVICE_ACCOUNT_JSON).
# Single-line JSON. Required inside containers; the file-path form
# (GOOGLE_APPLICATION_CREDENTIALS) doesn't work here because the path
# isn't mounted.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── DB + Redis (compose-internal hostnames — do not change) ──────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/nova
REDIS_URL=redis://redis:6379

# ── AI models ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
TRANSCRIBER_BACKEND=gemini
WHISPER_BACKEND=openai-api

# ── Feature flags that change render output ──────────────────────────────────
# Layer-2 text-overlay pipeline. Fly default: false. If your branch flips this
# locally without flipping it on Fly, your overlays will differ.
TEXT_OVERLAY_V2_ENABLED=false

# Upload orientation normalisation. Fly default: true. Setting false leaves
# input pixels untransposed and bypasses the auto-rotate pixel pass.
ORIENTATION_NORMALIZE_ENABLED=true

# Single-pass FFmpeg encode. Fly default: false. When true, stages 1-6 collapse
# into one filter_complex — visibly different intermediate behavior.
SINGLE_PASS_ENCODE_ENABLED=false

# Skia vs Pillow+libass text renderer for agentic/music. Fly default: true.
TEXT_RENDERER_SKIA_ENABLED=true

# Auto-music mode (Phase 3 of the feature). Fly default: false.
ENABLE_AUTO_MUSIC_MODE=false

# ── Admin (only needed if you submit jobs through admin endpoints) ───────────
ADMIN_API_KEY=

# ── CORS — only matters if you point a local browser at this stack ───────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8001"]
