FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libmagic1 \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml .
# Install with optional local-whisper deps for GPU worker
RUN pip install --no-cache-dir --upgrade pip setuptools && pip install --no-cache-dir -e ".[local-whisper]"

COPY . .

CMD ["celery", "-A", "app.worker", "worker", "--loglevel=info", "--concurrency=1"]
