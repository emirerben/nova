# Kria — Environment Variables
# Copy to .env: cp .env.example .env

# ── Storage ────────────────────────────────────────────────────────────────────
# Cloud storage bucket for raw uploads + processed outputs (never git-tracked)
STORAGE_BUCKET=nova-videos-dev
STORAGE_PROVIDER=gcs        # "gcs" or "s3"
# GCS: set GOOGLE_APPLICATION_CREDENTIALS path (local dev)
#      or  GOOGLE_SERVICE_ACCOUNT_JSON with raw JSON (Fly.io / containers)
# S3: set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY

# ── Job Queue (Redis) ──────────────────────────────────────────────────────────
# Native dev (running outside Docker):
REDIS_URL=redis://localhost:6379
# Docker Compose: use service name instead of localhost
# REDIS_URL=redis://redis:6379

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Native dev (running outside Docker):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nova
# Docker Compose: use service name instead of localhost
# DATABASE_URL=postgresql://postgres:postgres@db:5432/nova
# Note: the Celery worker always needs the plain postgresql:// form (no +asyncpg).
# FastAPI's async engine adds +asyncpg automatically — don't put it in .env.

# ── AI Models ─────────────────────────────────────────────────────────────────
# Gemini (primary — video analysis, transcription, copy writing)
GEMINI_API_KEY=AIza...

# OpenAI (Whisper fallback — used only if Gemini transcription fails or TRANSCRIBER_BACKEND=whisper)
OPENAI_API_KEY=sk-...

# Transcription backend: gemini (default) | whisper (forces OpenAI Whisper)
TRANSCRIBER_BACKEND=gemini

# Whisper backend: openai-api (default/prod) | local (dev only — too slow for prod SLA)
WHISPER_BACKEND=openai-api
# WHISPER_MODEL=base.en       # for local backend only

# ── Admin ──────────────────────────────────────────────────────────────────────
# Secret token for admin endpoints (POST /admin/templates etc.)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=
# Next.js admin proxy reads this server-side to forward to FastAPI.
# Must match ADMIN_API_KEY above. Set in src/apps/web/.env.local (never NEXT_PUBLIC_).
ADMIN_TOKEN=

# Internal server-to-server key for the Next.js plan proxy → FastAPI.
# Set to any random string; must match INTERNAL_API_KEY in the web env.
# SECURITY (fail-closed): strict plan routes REJECT (401) when this is unset —
# they never trust an X-User-Id header without a matching key. It MUST be set in
# every environment that serves plan routes (set it as a Fly secret before deploy).
INTERNAL_API_KEY=dev-internal-key-change-in-prod

# Local-only sign-in: enables the `dev-login` NextAuth provider (src/apps/web/src/lib/auth.ts)
# so the Google-gated content-plan flow can be exercised on localhost without Google
# consent. dev-auto.sh sources this file, so setting it here makes EVERY worktree's
# local dev have dev-login. Sign in at http://localhost:3000/api/auth/signin →
# "Dev login (local only)" → any email. NEVER set this in Vercel/Fly (it would let
# anyone mint a session for any email). Leave UNSET to disable.
ALLOW_DEV_LOGIN=true
# Prod admin token (Fly secrets `ADMIN_API_KEY` on nova-video). Read ONLY by
# scripts/admin.py --prod. Fetch with: fly ssh console -a nova-video -C "printenv ADMIN_API_KEY"
ADMIN_PROD_API_KEY=

# BasicAuth gate for /admin/* pages and /api/admin/* proxy. Read by
# src/apps/web/src/middleware.ts at module init. Both MUST be set or the
# middleware returns 503 "Admin auth not configured" (fail closed). Stopgap
# until per-user auth lands; rotate by redeploying with a new value.
# Vercel: `vercel env add ADMIN_BASIC_AUTH_USER` (Production) + same for PASSWORD.
# Local: also set in src/apps/web/.env.local.
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=

# Optional yt-dlp cookies for admin URL imports. Prefer YTDLP_COOKIES_B64 for
# hosted secrets; the API decodes it into a short-lived 0600 temp file. Use
# exactly one of these. Cookie files must be Netscape cookies.txt format.
YTDLP_COOKIES_B64=
YTDLP_COOKIES_PATH=

# ── Templates ──────────────────────────────────────────────────────────────────
# Optional: default template ID pre-selected on /template page
DEFAULT_TEMPLATE_ID=

# ── Waitlist ───────────────────────────────────────────────────────────────────
# Secret header for GET /api/admin/waitlist — set to a random string in prod
WAITLIST_ADMIN_SECRET=changeme

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Transactional email for waitlist confirmation. Leave empty to skip emails.
# Sign up at resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=

# CORS allowed origins — comma-separated (no spaces)
# Prod example: ALLOWED_ORIGINS=https://usekria.com,https://nova-video.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Security ───────────────────────────────────────────────────────────────────
# AES-256 Fernet key for OAuth token encryption at rest (NOT user-id-derived)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── OAuth Credentials ──────────────────────────────────────────────────────────
# Instagram (Meta Developer App — requires Business Manager setup before OAuth)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/auth/instagram/callback

# Google OAuth for user sign-in (Google Cloud Console — OAuth 2.0 Client ID)
# Replaces YOUTUBE_CLIENT_ID/SECRET.  Old names still work as a fallback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Legacy aliases (kept for backward compat during secret rename)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/auth/youtube/callback

# TikTok (Phase 3 — apply for Content API approval NOW; 4-8 week window)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/auth/tiktok/callback

# ── NextAuth.js ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
# Production: NEXTAUTH_URL=https://usekria.com
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal server-to-server auth key (Next.js plan proxy → FastAPI).
# Set to any random string; must match INTERNAL_API_KEY on the API side.
# The plan proxy refuses to forward when this is unset, and the API rejects
# any request without a matching key — so it must be set to use plan routes.
INTERNAL_API_KEY=dev-internal-key-change-in-prod
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Item-page "Edit" entry into the full-screen TikTok-style variant editor shell. Frontend-only flag; default OFF.
NEXT_PUBLIC_TIKTOK_EDITOR_ENABLED=false

# ── Architecture Dashboard ───────────────────────────────────────────────────
# GitHub personal access token (read-only scope: repo:read) for issue/commit data
# on the /architecture page. Optional — page works without it, badges show "?".
GITHUB_TOKEN=
# GitHub repo in "owner/name" format. Defaults to emirerben/nova.
GITHUB_REPO=emirerben/nova

# ── Observability ──────────────────────────────────────────────────────────────
# Optional: Langfuse for LLM observability. See src/apps/api/OBSERVABILITY.md.
# For local self-hosted: run `docker-compose -f docker-compose.langfuse.yml up -d`
# then open http://localhost:3030, sign up, create a project, and paste keys here.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Pipeline kill switches ───────────────────────────────────────────────────
# Set to `false` and restart workers to make `app/pipeline/orientation.normalize_orientation`
# a no-op. Safety valve for orientation regressions — leaves uploads with their
# original Display Matrix flag intact, downstream pipeline sees raw pixel dims
# (pre-PR-192 behavior, may yan-yatık iPhone portraits but won't ship upside-down).
# Apply via Fly: `fly secrets set ORIENTATION_NORMALIZE_ENABLED=false --app nova-video`
# then `fly machine restart <worker-id>`.
ORIENTATION_NORMALIZE_ENABLED=true
GENERATIVE_FAST_REBURN_ENABLED=true   # set to false to disable fast reburn on font/size edits

# Editorial transcript-synced typographic sequence on cluster variants with
# audible, coherent original speech. Set to `false` to revert to the legacy
# single static cluster (byte-identical). Read at render time.
# Apply via Fly: `fly secrets set EDITORIAL_SEQUENCE_ENABLED=false --app nova-video`
# then `fly machine restart <worker-id>`.
EDITORIAL_SEQUENCE_ENABLED=true

# Dynamic crossfade scheduling for line-style lyric overlays. When `true`
# (default), `app/pipeline/lyric_injector._inject_line` matches per-pair fade
# durations and tags the outgoing overlay with `fade_out_curve="sqrt"` so both
# renderers use mirror-symmetric fade curves during inter-line crossfades
# (α_L_N + α_L_N+1 = 1 at every t in the crossfade window — no readable
# stacked text at line boundaries). Set to `false` and restart workers to
# fall back to legacy scheduler behavior byte-identically (the pre-fix
# additive `fade_in_s + fade_out_s` cap, no curve tag emitted) — see
# `lyric_dynamic_crossfade_enabled` in app/config.py and the kill-switch
# snapshot test in tests/pipeline/test_lyric_injector_no_stacking.py.
# Apply via Fly: `fly secrets set LYRIC_DYNAMIC_CROSSFADE_ENABLED=false --app nova-video`
# then `fly machine restart <worker-id>`.
LYRIC_DYNAMIC_CROSSFADE_ENABLED=true

# Sound-effects glossary + user SFX placement on plan-item variants (the SFX lane
# in the timeline editor). Default OFF — must be set to `true` to enable the
# write/render routes (PUT /plan-items/{id}/variants/{vid}/sound-effects +
# .../render-sfx). When OFF those routes return 404 while GET /sound-effects (the
# picker list) still works — so the frontend lane can appear (it has its OWN flag,
# NEXT_PUBLIC_SOUND_EFFECTS_ENABLED, set in src/apps/web/.env.local / Vercel) yet
# saves silently fail. KEEP THE TWO FLAGS IN SYNC across Fly + Vercel.
# Apply via Fly: `fly secrets set SOUND_EFFECTS_ENABLED=true --app nova-video`
# then `fly machine restart <id>` (api + worker).
SOUND_EFFECTS_ENABLED=false

# Media-overlay cards (image/video overlays placed on plan-item variants — the
# Overlays lane in the timeline editor). Same dual-flag shape as SFX above:
# default OFF; when OFF the write routes (POST /plan-items/{id}/overlays-upload-urls
# + PUT .../media-overlays) return 404. Frontend lane has its own flag,
# NEXT_PUBLIC_MEDIA_OVERLAYS_ENABLED — keep both in sync across Fly + Vercel.
# Apply via Fly: `fly secrets set MEDIA_OVERLAYS_ENABLED=true --app nova-video`
# then `fly machine restart <id>` (api + worker).
MEDIA_OVERLAYS_ENABLED=false

# Overlay auto-placement (plans/005 — AI matches pool assets to transcript moments).
# PR0 gates the plan-item asset-pool routes (POST/GET/DELETE /plan-items/{id}/assets*);
# later PRs gate the matcher + suggestion routes behind the same flag. Same dual-flag
# shape as SFX/overlays above: frontend section has its own flag,
# NEXT_PUBLIC_OVERLAY_AUTOPLACE_ENABLED — keep both in sync across Fly + Vercel.
# Apply via Fly: `fly secrets set OVERLAY_AUTOPLACE_ENABLED=true --app nova-video`
# then `fly machine restart <id>` (api + worker).
OVERLAY_AUTOPLACE_ENABLED=false

# Zero-click auto-apply (plans/007). After a plan-item generate render finalizes,
# matched visuals burn in WITHOUT review on speech-bearing variants. Dedicated
# kill switch — turning this off never kills manual suggest (OVERLAY_AUTOPLACE_ENABLED).
# Apply via Fly: `fly secrets set OVERLAY_AUTOAPPLY_ENABLED=true --app nova-video` + worker restart.
OVERLAY_AUTOAPPLY_ENABLED=false

# Full-screen cutaway takeovers (plan 009). Gates ONLY the AI suggestion branch
# (slot "full" → display_mode=fullscreen). The frontend has its OWN twin flag,
# NEXT_PUBLIC_FULLSCREEN_CUTAWAYS_ENABLED (src/apps/web/.env.local / Vercel),
# which gates the MANUAL fullscreen PROMOTE affordances (popover "Full screen"
# option, "Make full screen →", F-to-fullscreen). Version-skew rule (R2/C8):
# a manual fullscreen previewed on new web + OLD api bakes as pip (Pydantic
# extra="ignore" strips display_mode). So keep the Vercel flag FALSE until THIS
# api flag's deploy is live on Fly, then flip Vercel AFTER Fly (never before).
# Default false — flip on Fly ONLY after the T4/T5 web surfaces are live on
# Vercel (preview/bake parity). Apply: `fly secrets set
# FULLSCREEN_CUTAWAYS_ENABLED=true --app nova-video` + worker restart.
FULLSCREEN_CUTAWAYS_ENABLED=false
# Subtitled single-clip edit style (talk-to-camera clip → auto-detected-language
# captions, editable + reburnable; Turkish + English via whisper-1 + a GPT
# correction pass). Same dual-flag shape as SFX above: default OFF; when OFF a
# subtitled job falls back to montage. Frontend picker card has its own flag,
# NEXT_PUBLIC_SUBTITLED_ENABLED (Vercel) — keep both in sync across Fly + Vercel.
# Apply via Fly: `fly secrets set SUBTITLED_ARCHETYPE_ENABLED=true --app nova-video`
# then `fly machine restart <id>` (api + worker).
SUBTITLED_ARCHETYPE_ENABLED=false
# Caption correction (subtitled): LLM pass fixing whisper's spelling/grammar
# mishearings per cue, timing preserved. gpt-4o is the accuracy-validated default
# (gpt-4o-mini missed Turkish case errors 4/4 runs). Kill switch below.
SUBTITLED_CAPTION_CORRECTION_ENABLED=true
CAPTION_CORRECTION_MODEL=gpt-4o
# Self-narration for narrated walkthroughs: generate WITHOUT a recorded voiceover
# when the footage's own audio carries the voice (1 clip → subtitled captions,
# 2+ → talking_head spine; no speech → montage + user-visible banner). SOLE gate
# for the branch — deliberately independent of the two archetype flags above.
# Frontend twin: NEXT_PUBLIC_NARRATED_SELF_NARRATION_ENABLED (Vercel). Flip Fly
# first (`fly secrets set NARRATED_SELF_NARRATION_ENABLED=true --app nova-video`
# + machine restart), then Vercel.
NARRATED_SELF_NARRATION_ENABLED=false
